Algoritmo GA2U2Ejercicio2enCasa
	Definir c Como Caracter
	Escribir Sin Saltar "Digite una caracter:"
	Leer c
	Segun c Hacer
		"1" o "2" o "3" o "4" o "5" o "6" o "7" o "8" o "9":
			Escribir "Su caracter es un digito"
		"A" o "a"o "E" o "e" o "I" o "i" o "O" o "o" o "U" o "u":
			Escribir "Su caracter es una vocal"	
		De Otro Modo:
			Escribir "Su caracter no es ni digito ni vocal"
	Fin Segun
FinAlgoritmo
